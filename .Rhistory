# ─────────────────────────────────────────────────────────────────────────────
# Usage notes:
# • Set `dpi` ≥ 300 for on-screen quality, 600+ for print-ready clarity.
# • Files are named <pdfname>_page01.png, <pdfname>_page02.png, …
# • Each page becomes an independent PNG, preserving original dimensions
#   (scaled by the selected DPI).
# • Poppler must be available; on Windows, pdftools ships pre-compiled binaries.
# ─────────────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# PDF ➜ PNG  *plus* Markdown snippet generator
# Converts every page of every PDF in a directory to PNG (print quality)
# and writes Markdown links of the form  ![<alt>](<path>)
#
# Dependencies ▸ pdftools  ▸ fs  (install on first run if needed)
# ─────────────────────────────────────────────────────────────────────────────
# 1) Load / install packages --------------------------------------------------
need <- c("pdftools", "fs")
new  <- need[!vapply(need, requireNamespace, FALSE, quietly = TRUE)]
if (length(new)) install.packages(new)
lapply(need, library, character.only = TRUE)
# 2) User params --------------------------------------------------------------
input_dir  <- "tableau"  # 📂 PDFs live here
output_dir <- input_dir  # 📂 PNGs will be written here
dpi        <- 300        # 🖨  300+ for print
overwrite   <- FALSE     # 🔄 skip pages already converted?
make_md     <- TRUE      # 📝 write ./images.md with links?
# 3) Ensure output folder exists ---------------------------------------------
if (!dir_exists(output_dir)) dir_create(output_dir)
# 4) Workhorse ----------------------------------------------------------------
convert_one_pdf <- function(pdf) {
info <- pdf_info(pdf)                         # one expensive call
n_pages <- info$pages
base    <- path_ext_remove(path_file(pdf))    # filename w/out .pdf
pattern <- path(output_dir, paste0(base, "_page%02d.png"))
targets <- sprintf(pattern, seq_len(n_pages))
if (!overwrite && all(file_exists(targets))) {
message("• Skipping ", base, " (already done)")
return(targets)
}
# Render every page in a single call (vectorised filenames)
pdf_convert(pdf,
format    = "png",
dpi       = dpi,
filenames = targets)
}
# 5) Batch convert ------------------------------------------------------------
pdfs <- dir_ls(input_dir, glob = "*.pdf", recurse = FALSE)
if (!length(pdfs))
stop("No PDF files found in ", input_dir)
png_paths <- unlist(lapply(pdfs, convert_one_pdf))
# 6) Emit Markdown ------------------------------------------------------------
if (make_md) {
rel_paths <- path_rel(png_paths, start = ".")          # nice relative links
alt_text  <- path_file(path_ext_remove(rel_paths))     # sensible alt tags
md_lines  <- sprintf("![%s](%s)", alt_text, rel_paths)
writeLines(md_lines, "images.md")
message("\n✓ images.md created with ", length(md_lines), " links.")
}
# ─────────────────────────────────────────────────────────────────────────────
# NOTES
#  • The code creates PNGs named <pdfname>_page01.png, _page02.png, …
#  • `images.md` holds ready-made Markdown — just drop it into any .md / .Rmd.
#  • In an .Rmd chunk you can also do:
#       ```{r, echo=FALSE}
#       knitr::include_graphics("<path/to/png>")
#       ```
#    which will respect figure sizing options.
# ─────────────────────────────────────────────────────────────────────────────
# PDF ➜ SVG *plus* Markdown snippet generator
# Converts every page of every PDF in a directory to SVG (vector)
# and writes Markdown links of the form ![<alt>](<path>)
#
# Dependencies: pacman; requires `pdf2svg` CLI tool
# -----------------------------------------------------------------------------
# 1) Load / install packages via pacman
if (!requireNamespace("pacman", quietly = TRUE)) install.packages("pacman")
pacman::p_load(fs, pdftools)
# 2) User params
input_dir  <- "tableau"    # 📂 PDFs live here
output_dir <- input_dir      # 📂 SVGs will be written here
overwrite  <- FALSE         # 🔄 skip pages already converted?
make_md    <- TRUE           # 📝 write ./images.md with links?
# 3) Ensure output folder exists
if (!fs::dir_exists(output_dir)) fs::dir_create(output_dir)
# 4) Workhorse: convert one PDF to multiple SVGs
convert_one_pdf <- function(pdf) {
info    <- pdftools::pdf_info(pdf)
n_pages <- info$pages
base    <- fs::path_ext_remove(fs::path_file(pdf))
targets <- fs::path(output_dir, sprintf("%s_page%02d.svg", base, seq_len(n_pages)))
if (!overwrite && all(fs::file_exists(targets))) {
message("• Skipping ", base, " (already done)")
return(targets)
}
for (i in seq_len(n_pages)) {
svg_file <- targets[i]
# Call pdf2svg: pdf2svg <input.pdf> <output.svg> <page_number>
res <- system2("pdf2svg", args = c(shQuote(pdf), shQuote(svg_file), i))
if (res != 0) warning("pdf2svg failed for ", pdf, " page ", i)
}
targets
}
# 5) Batch convert
pdfs <- fs::dir_ls(input_dir, glob = "*.pdf", recurse = FALSE)
if (!length(pdfs)) stop("No PDF files found in ", input_dir)
svg_paths <- unlist(lapply(pdfs, convert_one_pdf))
# 6) Emit Markdown
if (make_md) {
rel_paths <- fs::path_rel(svg_paths, start = ".")
alt_text  <- fs::path_file(fs::path_ext_remove(rel_paths))
md_lines  <- sprintf("![%s](%s)", alt_text, rel_paths)
writeLines(md_lines, "images.md")
message("\n✓ images.md created with ", length(md_lines), " links.")
}
