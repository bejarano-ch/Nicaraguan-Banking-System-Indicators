# ─────────────────────────────────────────────────────────────────────
# Batch PDF ➜ SVG (vectorial) con Inkscape CLI
# ─────────────────────────────────────────────────────────────────────
# 1) Carga o instala paquetes necesarios
if (!requireNamespace("pacman", quietly = TRUE)) install.packages("pacman")
pacman::p_load(fs, purrr, glue)
# 2) Parámetros de usuario
input_dir  <- "tableau"           # Carpeta con tus PDFs
output_dir <- file.path(input_dir, "svg")  # Carpeta destino para los SVG
dir_create(output_dir)            # Crea la carpeta si no existe
# 3) Verifica que Inkscape esté disponible
ink_path <- Sys.which("inkscape")
if (ink_path == "") {
stop("❌ No se encontró 'inkscape' en el PATH del sistema.
Asegúrate de instalar Inkscape y de tenerlo accesible desde la terminal.")
}
# 4) Función de conversión para un PDF (página única)
convert_pdf_to_svg <- function(pdf_path) {
base    <- path_ext_remove(path_file(pdf_path))
out_svg <- path(output_dir, paste0(base, ".svg"))
# Construye los argumentos de Inkscape
args <- c(
"--pdf-page=1",
"--export-type=svg",
glue::glue("--export-filename={out_svg}"),
pdf_path
)
# Ejecuta Inkscape
res <- system2(ink_path, args = args, stdout = TRUE, stderr = TRUE)
if (length(res) == 0) {
message(glue::glue("✔ '{base}.pdf' ➜ '{base}.svg'"))
} else {
warning(glue::glue("⚠️ Error al convertir '{base}.pdf':\n{paste(res, collapse = '\n')}"))
}
}
# 5) Aplica la función a todos los PDFs en la carpeta
pdf_files <- dir_ls(input_dir, regexp = "\\.pdf$", recurse = FALSE)
if (length(pdf_files) == 0) {
stop("No se encontraron archivos .pdf en '", input_dir, "'.")
}
purrr::walk(pdf_files, convert_pdf_to_svg)
