              <calculation class='tableau' formula='#2025-04-30#' />
              <range granularity='1' period-type-v2='month' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1hpps7e10u3ana1f42duh133xskq'>
