            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='target_date' datatype='date' default-format='*mmm-yy' name='[Parámetro 1]' param-domain-type='range' role='measure' source-field='[federated.1hpps7e10u3ana1f42duh133xskq].[fecha]' type='quantitative' value='#2025-04-30#'>
