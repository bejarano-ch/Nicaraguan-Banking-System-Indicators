              <calculation class='tableau' formula='CASE [level_2]&#13;&#10;    WHEN &quot;Efectivo&quot; THEN &quot;El &quot; + PROPER([level_2])&#13;&#10;    WHEN &quot;Inversiones&quot; THEN &quot;Las &quot; + PROPER([level_2])&#13;&#10;    WHEN &quot;Cartera bruta de créditos&quot; THEN &quot;La &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Otros activos&quot; THEN &quot;Los &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Obligaciones con el público&quot; THEN &quot;Las &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Depósitos de Instituciones&quot; THEN &quot;Los &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Obligaciones con Instituciones&quot; THEN &quot;Las &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Otros pasivos&quot; THEN &quot;Los &quot; + LOWER([level_2])&#13;&#10;    ELSE LOWER([level_2])  // Convierte cualquier otro valor a minúsculas&#13;&#10;END' />
            </column>
            <column caption='Fecha' datatype='date' datatype-customized='true' name='[fecha]' role='dimension' type='ordinal' />
