      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1hpps7e10u3ana1f42duh133xskq].[pcdf:sum:valor:qk:3]&quot;' value='YoY growth' />
          <alias key='&quot;[federated.1hpps7e10u3ana1f42duh133xskq].[sum:valor:qk]&quot;' value='Balance' />
          <alias key='&quot;[federated.1hpps7e10u3ana1f42duh133xskq].[usr:Calculation_1210342449620553739:qk:1]&quot;' value='YoY growth (right axis)' />
        </aliases>
      </column>
      <column caption='Last_date' datatype='date' name='[Calculation_1210342449606426624]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED : MAX([fecha]) }' />
      </column>
      <column caption='Filter_same_month' datatype='boolean' name='[Calculation_1210342449606852609]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='MONTH([fecha]) = MONTH([Parameters].[Parámetro 1])' />
      </column>
      <column caption='Filter_three_years' datatype='boolean' name='[Calculation_1210342449607901187]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[fecha] &gt;= DATEADD(&apos;year&apos;, -3, [Parameters].[Parámetro 1]) AND&#13;&#10;[fecha] &lt;= [Parameters].[Parámetro 1]' />
      </column>
      <column caption='Growth_rate' datatype='real' name='[Calculation_1210342449608699909]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([valor])/LOOKUP(SUM([valor]), -1)*100-100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Filter_last_date' datatype='boolean' name='[Calculation_1210342449611792391]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[fecha]=[Parameters].[Parámetro 1]' />
      </column>
      <column caption='Level 2 título' datatype='string' name='[Calculation_1210342449622577168]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [level_2]&#13;&#10;    WHEN &quot;Efectivo&quot; THEN &quot;El &quot; + PROPER([level_2])&#13;&#10;    WHEN &quot;Inversiones&quot; THEN &quot;Las &quot; + PROPER([level_2])&#13;&#10;    WHEN &quot;Cartera bruta de créditos&quot; THEN &quot;La &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Otros activos&quot; THEN &quot;Los &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Obligaciones con el público&quot; THEN &quot;Las &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Depósitos de Instituciones&quot; THEN &quot;Los &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Obligaciones con Instituciones&quot; THEN &quot;Las &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Otros pasivos&quot; THEN &quot;Los &quot; + LOWER([level_2])&#13;&#10;    ELSE LOWER([level_2])  // Convierte cualquier otro valor a minúsculas&#13;&#10;END' />
      </column>
      <column caption='Assets' datatype='real' name='[Calculation_492299753690542080]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Total de Assets por mes (en millones de córdobas)&#13;&#10;{ FIXED [fecha] :&#13;&#10;    SUM(&#13;&#10;      IF [level_1] = &quot;Assets&quot;&#13;&#10;      THEN [valor]&#13;&#10;      END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Filter_before_target_date' datatype='boolean' name='[Calculation_595882544955400205]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[fecha] &lt;= [Parameters].[Parámetro 1]' />
      </column>
      <column caption='Filtered Saldo LOD' datatype='real' name='[Calculation_634726122449666049]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [institucion] : &#13;&#10;    SUM(&#13;&#10;        IF [fecha] = [Calculation_1210342449606426624] THEN&#13;&#10;            [valor]&#13;&#10;        ELSE&#13;&#10;            0&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
