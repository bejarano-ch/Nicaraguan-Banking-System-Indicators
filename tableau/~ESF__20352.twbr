          <datasource-dependencies datasource='federated.1hpps7e10u3ana1f42duh133xskq'>
            <column caption='Last_date' datatype='date' name='[Calculation_1210342449606426624]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{ FIXED : MAX([fecha]) }' />
            </column>
            <column caption='Filter_last_date' datatype='boolean' name='[Calculation_1210342449611792391]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[fecha]=[Parameters].[Parámetro 1]' />
            </column>
            <column caption='Level 2 título' datatype='string' name='[Calculation_1210342449622577168]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [level_2]&#13;&#10;    WHEN &quot;Efectivo&quot; THEN &quot;El &quot; + PROPER([level_2])&#13;&#10;    WHEN &quot;Inversiones&quot; THEN &quot;Las &quot; + PROPER([level_2])&#13;&#10;    WHEN &quot;Cartera bruta de créditos&quot; THEN &quot;La &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Otros activos&quot; THEN &quot;Los &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Obligaciones con el público&quot; THEN &quot;Las &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Depósitos de Instituciones&quot; THEN &quot;Los &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Obligaciones con Instituciones&quot; THEN &quot;Las &quot; + LOWER([level_2])&#13;&#10;    WHEN &quot;Otros pasivos&quot; THEN &quot;Los &quot; + LOWER([level_2])&#13;&#10;    ELSE LOWER([level_2])  // Convierte cualquier otro valor a minúsculas&#13;&#10;END' />
            </column>
            <column caption='SUM([Valor]) / TOTAL(SUM([Valor]))*100' datatype='real' name='[Calculation_595882544925667335]' role='measure' type='quantitative' user:unnamed='Graph_2'>
              <calculation class='tableau' formula='SUM([valor]) / TOTAL(SUM([valor]))*100'>
                <table-calc ordering-type='Rows' />
